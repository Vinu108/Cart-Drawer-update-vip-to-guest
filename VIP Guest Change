 $(document).on('click', '.cart-item[var_id="52722469208384"] cart-remove-button button', function () {

  setTimeout(function () {
    // thoda delay taaki pehle remove wala AJAX complete ho jaye
    $('tr.cart-item[data-is-vip="true"]').each(function () {
      const guestVariantId = $(this).data('guest-variant-id');
      const lineKey = $(this).data('line-key');
      const qtyInput = $(this).find('.quantity__input');
      const qty = qtyInput.length ? parseInt(qtyInput.val()) : 1;

      if (!guestVariantId || !lineKey) return;

      // Step A: purana VIP line item remove karo
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: lineKey,
          quantity: 0
        })
      })
      .then(res => res.json())
      .then(() => {
        // Step B: naya Guest variant add karo
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: guestVariantId, quantity: qty }]
          })
        });
      })
      .then(res => res.json())
      .then(() => {
        // Step C: cart section refresh (drawer re-render)
        return fetch('/?sections=cart-drawer')
          .then(res => res.json());
      })
      .then(sections => {
        document.querySelector('cart-drawer').innerHTML =
          new DOMParser().parseFromString(sections['cart-drawer'], 'text/html')
            .querySelector('cart-drawer').innerHTML;
      });
    });
  }, 800); // remove animation/AJAX ke baad chalayein

});
