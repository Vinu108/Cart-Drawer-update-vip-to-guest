{%- liquid
  assign is_vip = false
  assign guest_variant_id = ""

  for option in item.options_with_values
    if option.name == "User Type" and option.value == "VIP Price"
      assign is_vip = true
    endif
  endfor

  if is_vip
    for variant in item.product.variants
      assign matched = true
      for option in item.product.options_with_values
        assign opt_index = forloop.index0
        assign variant_value = variant.options[opt_index]

        if option.name == "User Type"
          unless variant_value == "Guest Price"
            assign matched = false
          endunless
        else
          assign current_value = item.options_with_values[opt_index].value
          unless variant_value == current_value
            assign matched = false
          endunless
        endif
      endfor

      if matched
        assign guest_variant_id = variant.id
      endif
    endfor
  endif
-%}
                      <tr
  data-la-dn-cart-item-row data-la-dn-cart-item-key="{{ item.key }}"
  id="CartDrawer-Item-{{ item.index | plus: 1 }}"
  class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
  role="row"
  {% if item.parent_relationship.parent != null %}
    aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
  {% endif %}
  var_id ="{{ item.variant_id }}" 
  data-is-vip="{{ is_vip }}"
  data-guest-variant-id="{{ guest_variant_id }}"
  data-line-key="{{ item.key }}"
>







